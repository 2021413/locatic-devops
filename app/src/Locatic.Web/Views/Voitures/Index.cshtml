@model IReadOnlyList<Voiture>
@{
    ViewData["Title"] = "Voitures";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Parc de voitures</h1>
    <a class="btn btn-primary" asp-action="Create">+ Ajouter une voiture</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Aucune voiture dans le parc.</div>
}
else
{
    <div class="card shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Immatriculation</th>
                    <th>Marque</th>
                    <th>Modèle</th>
                    <th>Année</th>
                    <th>Carburant</th>
                    <th class="text-end">Tarif / jour</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var voiture in Model)
                {
                    <tr>
                        <td><code>@voiture.Immatriculation</code></td>
                        <td>@voiture.Modele?.Marque?.Nom</td>
                        <td>@voiture.Modele?.Nom</td>
                        <td>@voiture.Annee</td>
                        <td>@voiture.Carburant</td>
                        <td class="text-end">@voiture.TarifJournalier.ToString("0.00") €</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@voiture.Id">Détail</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@voiture.Id">Modifier</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@voiture.Id">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
