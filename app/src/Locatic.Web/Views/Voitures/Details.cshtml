@model Voiture
@{
    ViewData["Title"] = "Détail de la voiture";
}

<h1 class="h3 mb-4">Détail de la voiture</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Immatriculation</dt>
            <dd class="col-sm-9"><code>@Model.Immatriculation</code></dd>

            <dt class="col-sm-3">Marque</dt>
            <dd class="col-sm-9">@Model.Modele?.Marque?.Nom</dd>

            <dt class="col-sm-3">Modèle</dt>
            <dd class="col-sm-9">@Model.Modele?.Nom</dd>

            <dt class="col-sm-3">Année</dt>
            <dd class="col-sm-9">@Model.Annee</dd>

            <dt class="col-sm-3">Carburant</dt>
            <dd class="col-sm-9">@Model.Carburant</dd>

            <dt class="col-sm-3">Nombre de places</dt>
            <dd class="col-sm-9">@Model.NombrePlaces</dd>

            <dt class="col-sm-3">Tarif journalier</dt>
            <dd class="col-sm-9">@Model.TarifJournalier.ToString("0.00") €</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Modifier</a>
        <a class="btn btn-link" asp-action="Index">Retour à la liste</a>
    </div>
</div>
